{
  "name": "otp-service-package",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Production-grade OTP infrastructure package family for Node.js services.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suraj-H/otp-service-package.git"
  },
  "bugs": {
    "url": "https://github.com/Suraj-H/otp-service-package/issues"
  },
  "homepage": "https://github.com/Suraj-H/otp-service-package#readme",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:package-runtime": "pnpm build && node scripts/prepare-publishability-fixture.mjs && node scripts/verify-package-runtime.mjs && node scripts/run-publishability-consumer.mjs runtime",
    "verify:package-types": "pnpm build && node scripts/prepare-publishability-fixture.mjs && node scripts/run-publishability-consumer.mjs types",
    "verify:publishability": "pnpm verify:package-runtime && pnpm verify:package-types",
    "clean": "pnpm -r --if-present clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm build && changeset publish",
    "sync-repo-url": "node scripts/sync-repository-url.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "eslint --max-warnings=0 --fix"
    ],
    "*.mjs": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "express": "^5.1.0",
    "fastify": "^5.3.3",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
