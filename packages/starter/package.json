{
  "name": "@otp-service/starter",
  "version": "0.1.2",
  "type": "module",
  "description": "Thin starter composition helpers for the common OTP adoption path.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suraj-H/otp-service-package.git"
  },
  "bugs": {
    "url": "https://github.com/Suraj-H/otp-service-package/issues"
  },
  "homepage": "https://github.com/Suraj-H/otp-service-package/tree/main/packages/starter#readme",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "lint": "eslint src test",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@otp-service/core": "workspace:*",
    "@otp-service/provider-email-resend": "workspace:*",
    "@otp-service/provider-sms-twilio": "workspace:*",
    "@otp-service/redis-store": "workspace:*"
  }
}
